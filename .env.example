# Frontend — copy to .env.local and fill in values
# Never commit .env.local

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key   # Lovable's name for the anon key
VITE_SUPABASE_ANON_KEY=your-anon-key          # fallback for local dev without Lovable
VITE_SUPABASE_PROJECT_ID=your-project-ref

# PostHog analytics (optional in dev)
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry (optional in dev)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# App version (set in CI)
VITE_APP_VERSION=0.1.0
